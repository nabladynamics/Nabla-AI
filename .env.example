# Nabla AI — environment configuration template.
#
# Copy to `.env` (git-ignored) and fill in what you need. Every variable has a
# safe default; an empty `.env` (or none at all) runs the full local stack.
#
#   cp .env.example .env
#
# The backend reads NABLA_* variables (see backend/app/config.py for the
# authoritative list + defaults). docker-compose.yml reads the NABLA_*_PORT
# variables and forwards the rest into the backend container.

# --- Secrets (NEVER commit real values; `.env` is git-ignored) ---------------

# Anthropic API key for the AI experiment co-pilot. Read by the Anthropic SDK
# from this standard variable — it is intentionally NOT a NABLA_* setting and
# is never persisted by the backend. Leave unset to run without the co-pilot
# (every other feature works; /api/ai/ask returns an explanatory error).
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ports (host side; compose + scripts) ------------------------------------

# Host port for the backend API (container listens on 8000 internally).
# NABLA_BACKEND_PORT=8000

# Host port for the frontend (container nginx listens on 80 internally).
# NABLA_FRONTEND_PORT=8080

# --- Backend (prefix NABLA_, defaults in backend/app/config.py) --------------

# Command used to invoke the solver core CLI (shlex-split; may include args).
# Local dev default: ../core/build/nabla_solve. In the container: /usr/local/bin/nabla_solve.
# NABLA_SOLVER_COMMAND=../core/build/nabla_solve

# Root for run metadata (SQLite) and artifacts (filesystem store).
# Local dev default: .nabla-data (inside backend/). In the container: /data (named volume).
# NABLA_DATA_DIR=.nabla-data

# Wall-clock limit (seconds) for the synchronous geometry-ingest step.
# NABLA_INGEST_TIMEOUT_S=300

# Anthropic model used by the experiment co-pilot.
# NABLA_ANTHROPIC_MODEL=claude-opus-4-8

# Repository root — locates the validation harness for report generation.
# Local dev default: .. (service runs from backend/). In the container: /app.
# NABLA_REPO_ROOT=..

# Git SHA reported by /health. Injected automatically by container builds and
# CI; leave unset for local dev ("unknown").
# NABLA_GIT_SHA=

# --- Solver numerics ----------------------------------------------------------
# Solver thresholds and tolerances (CFL, Poisson tol, AMR sensor thresholds,
# acceptance gates …) are NOT environment variables: they are per-run physics
# configuration, passed in each run's case.json through the file-based IPC
# contract and recorded with the run for reproducibility. See
# core/include/nabla/config.hpp and backend/app/models.py.
