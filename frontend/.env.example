# Nabla AI frontend — build-time configuration (Vite).
# Copy to `.env.local` for local overrides (git-ignored). Vite only exposes
# variables prefixed with VITE_ to the browser bundle.

# Backend base URL. The REST calls and the telemetry WebSocket both derive from
# this (the WS switches http->ws / https->wss automatically).
#
#   - Unset / empty (default): same-origin. `npm run dev` proxies /api to the
#     backend (vite.config.ts) and `docker compose up` proxies it through nginx,
#     so local development and the compose stack need NO value here.
#   - Vercel (production): set this to the deployed Railway backend URL, e.g.
#       VITE_API_BASE_URL=https://nabla-backend.up.railway.app
#   - Talking to a local backend WITHOUT the dev proxy: VITE_API_BASE_URL=http://localhost:8000
#
# VITE_API_BASE_URL=https://nabla-backend.up.railway.app
